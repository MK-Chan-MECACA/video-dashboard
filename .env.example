# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...

# --- HeyGen (paid API plan) ---
HEYGEN_API_KEY=
# Fallback voice if none saved in dashboard Settings
HEYGEN_VOICE_ID=

# --- WaveSpeed ---
WAVESPEED_API_KEY=
# From WaveSpeed dashboard > Webhooks (used to verify webhook signatures)
WAVESPEED_WEBHOOK_SECRET=

# --- GoHighLevel (Private Integration token with Social Planner scopes) ---
GHL_PRIVATE_TOKEN=
GHL_LOCATION_ID=
# Find via GET /social-media-posting/{locationId}/accounts (or Settings page in the dashboard)
# Comma-separated ids of connected GHL social accounts to post to (TikTok, Instagram, Facebook, ...)
GHL_SOCIAL_ACCOUNT_IDS=
GHL_USER_ID=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection for the worker (Supabase > Settings > Database, use the pooler "session" string)
DATABASE_URL=postgresql://postgres:...@db.xxxx.supabase.co:5432/postgres

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=my-media
# Public bucket domain (R2 > bucket > Settings > Public access), no trailing slash
R2_PUBLIC_BASE_URL=https://media.example.com

# --- App ---
# Public URL of the deployed web app (used for webhook callbacks + review links)
APP_URL=http://localhost:3000

# --- Worker ---
WORKER_CONCURRENCY=3

# --- Phase 4 (optional) ---
RESEND_API_KEY=
